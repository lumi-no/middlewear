#include <iostream>
#include <functional>
#include <string>

using namespace std;

using Func = function<string(string)>;

using Decorator = function<Func(Func)>;

string greet(string name)
{
    return "Hello, " + name;
}

Func add_stars(Func func)
{
    return [=](string name) -> string
    {
        return "*** " + func(name) + " ***";
    };
}

Func add_prefix(Func func)
{
    return [=](string name) -> string
    {
        return "[INFO] " + func(name);
    };
}

Decorator compose_decorators(Decorator d1, Decorator d2)
{
    return [=](Func func) -> Func
    {
        return d1(d2(func));
    };
}

int main()
{
    Decorator combined =
        compose_decorators(add_stars, add_prefix);

    Func decorated_greet = combined(greet);

    cout << decorated_greet("Anastasia") << endl;

    return 0;
}
