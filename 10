У цьому прикладі middleware функція виконується “посередині” між двома етапами обробки. 
#include <iostream>
#include <functional>
#include <string>

using namespace std;

string handle_request()
{
    return "OK";
}

function<string()> middleware(function<string()> func)
{
    return [func]()
    {
        cout << "Before request" << endl;

        string result = func();

        cout << "After request" << endl;

        return result;
    };
}

int main()
{
    function<string()> wrappedRequest =
        middleware(handle_request);

    string result = wrappedRequest();

    cout << "Result: "
         << result
         << endl;

    return 0;
}
