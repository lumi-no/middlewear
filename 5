#include <iostream>
#include <functional>
#include <string>


using namespace std;

int multiply(int a, int b)
{
    return a * b;
}

function<int(int, int)> positive_only(function<int(int, int)> func)
{
    return [func](int a, int b)
    {
        if (a <= 0 || b <= 0)
        {
            cout << "Error: arguments must be positive" << endl;

            return -1;
        }

        return func(a, b);
    };
}

int main()
{
    function<int(int, int)> safeMultiply =
        positive_only(multiply);

    cout << "Result: "
         << safeMultiply(2, 3)
         << endl;

    cout << endl;
    
    cout << "Result: "
         << safeMultiply(-2, 3)
         << endl;

    return 0;
}

сама функція multiply не змінюється, нова поведінка додається зовні, а декоратор контролює виклик функції. 
