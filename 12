#include <iostream>
#include <string>

using namespace std;

double divide(double a, double b)
{
    if (b == 0)
    {
        throw runtime_error("Division by zero");
    }

    return a / b;
}

string handle_errors(double a, double b)
{
    try
    {
        double result = divide(a, b);

        return "Result: " + to_string(result);
    }
    catch (exception&)
    {
        return "Error: division by zero!";
    }
}

int main()
{
    cout << handle_errors(10, 2) << endl;

    cout << handle_errors(10, 0) << endl;

    return 0;
}
