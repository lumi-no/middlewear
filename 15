#include <iostream>
#include <functional>
#include <string>

using namespace std;

string ping()
{
    return "pong";
}

function<string()> limit_calls(int n, function<string()> func)
{
    int counter = 0; 

    return [=]() mutable -> string
    {
        if (counter >= n)
        {
            return "Call limit exceeded";
        }

        counter++;

        return func();
    };
}

int main()
{
    auto limited_ping = limit_calls(3, ping);

    cout << limited_ping() << endl;
    cout << limited_ping() << endl;
    cout << limited_ping() << endl;
    cout << limited_ping() << endl;
    cout << limited_ping() << endl;

    return 0;
}
